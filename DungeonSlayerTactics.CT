define(address,Hero:UpdateBuffDispaly)
define(bytes,55 48 8B EC 48 83 EC 30)

[ENABLE]

assert(address,bytes)
alloc(newmem,$1000,Hero:UpdateBuffDispaly)

label(code)
label(return)

newmem:
