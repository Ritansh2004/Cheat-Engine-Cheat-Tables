<?xml version="1.0" encoding="utf-8"?>
<CheatTable CheatEngineTableVersion="46">
  <CheatEntries>
    <CheatEntry>
      <ID>170</ID>
      <Description>"Initialize Mono"</Description>
      <Options moHideChildren="1"/>
      <LastState Activated="1"/>
      <Color>FF8080</Color>
      <VariableType>Auto Assembler Script</VariableType>
      <AssemblerScript>[ENABLE]
{$lua}
if syntaxcheck then return end

local processName = "Mini Motorways.exe"
local pid = getProcessIDFromProcessName(processName)

if (pid == 0 or pid == nil) then
    -- 1. Notify the user
    showMessage("Start Game Process First..!!!")
    -- 2. Force the script to "crash" out of the Enable phase
    error("Process not found")
else
    -- Process found, proceed
    OpenProcess(processName)
    mono_initialize()
    LaunchMonoDataCollector()
    beep()                                               --For Sound
    showMessage("Made By DANGER DASH...!!!")             --Pop Up Message
end
{$asm}

[DISABLE]
{$lua}
if process then
    showMessage('Table Disabled!')
end
{$asm}

</AssemblerScript>
      <CheatEntries>
        <CheatEntry>
          <ID>0</ID>
          <Description>"UpgradeDatabase"</Description>
          <Options moHideChildren="1" moAllowManualCollapseAndExpand="1"/>
          <LastState Activated="1"/>
          <Color>80FFFF</Color>
          <VariableType>Auto Assembler Script</VariableType>
          <AssemblerScript>{ Game   : Mini Motorways.exe
  Version: 
  Date   : 2026-04-14
  Author : DANGER DASH

  This script does blah blah blah
}

define(address,Motorways.UpgradeDatabase:ConsumeUpgrade)
define(bytes,55 8B EC 53 57)

[ENABLE]


assert(address,bytes)
alloc(newmem,$1000,Motorways.UpgradeDatabase:ConsumeUpgrade)

label(code)
label(return)

newmem:
mov [upgradedatabase_ptr],ebx

code:
  push ebp
  mov ebp,esp
  push ebx
  push edi
  jmp return

upgradedatabase_ptr:
dd 0

address:
  jmp newmem
return:
registersymbol(upgradedatabase_ptr)

[DISABLE]

address:
  db bytes
  // push ebp
  // mov ebp,esp
  // push ebx
  // push edi

dealloc(newmem)
unregistersymbol(upgradedatabase_ptr)

{
// ORIGINAL CODE - INJECTION POINT: Motorways.UpgradeDatabase:ConsumeUpgrade

3D8C85BC: 00 00        - add [eax],al
3D8C85BE: 00 00        - add [eax],al
