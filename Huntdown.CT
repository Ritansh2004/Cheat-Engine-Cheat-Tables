define(address,Game:Update)
define(bytes,55 48 8B EC 48 83 EC 30)

[ENABLE]

assert(address,bytes)
alloc(newmem,$1000,Game:Update)

label(code)
label(return)

newmem:
mov [game_ptr],rcx

code:
  push rbp
  mov rbp,rsp
  sub rsp,30
  jmp return

game_ptr:
dq 0

address:
  jmp newmem
  nop 3
return:
registersymbol(game_ptr)

[DISABLE]

address:
  db bytes
  // push rbp
  // mov rbp,rsp
  // sub rsp,30

