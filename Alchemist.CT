define(address,BattleManager:Update)
define(bytes,48 83 EC 08 48 83 C4 08)

[ENABLE]

assert(address,bytes)
alloc(newmem,$1000,BattleManager:Update)

label(code)
label(return)

newmem:
mov [battlemanager_ptr],rcx

code:
  sub rsp,08
  add rsp,08
  jmp return

battlemanager_ptr:
dq 0

address:
  jmp newmem
  nop 3
return:
registersymbol(battlemanager_ptr)

[DISABLE]

