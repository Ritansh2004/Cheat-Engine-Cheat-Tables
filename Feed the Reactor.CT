2D8E5F3103C: 00 00                          - add [rax],al
2D8E5F3103E: 00 00                          - add [rax],al
// ---------- INJECTING HERE ----------
Player:Update: 55                             - push rbp
// ---------- DONE INJECTING  ----------
Player:Update+1: 48 8B EC                       - mov rbp,rsp
Player:Update+4: 48 83 EC 40                    - sub rsp,40
Player:Update+8: 48 89 75 F8                    - mov [rbp-08],rsi
Player:Update+c: 48 8B F1                       - mov rsi,rcx
Player:Update+f: F3 0F 10 86 74 05 00 00        - movss xmm0,[rsi+00000574]
Player:Update+17: F3 0F 5A C0                    - cvtss2sd xmm0,xmm0
Player:Update+1b: F2 0F 11 45 E8                 - movsd [rbp-18],xmm0
Player:Update+20: 48 8D 64 24 00                 - lea rsp,[rsp+00]
Player:Update+25: 90                             - nop 
Player:Update+26: 49 BB 10 11 A8 E1 D8 02 00 00  - mov r11,UnityEngine.Time:get_deltaTime
}
