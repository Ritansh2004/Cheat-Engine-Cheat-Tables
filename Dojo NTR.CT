<?xml version="1.0" encoding="utf-8"?>
<CheatTable CheatEngineTableVersion="46">
  <CheatEntries>
    <CheatEntry>
      <ID>102</ID>
      <Description>"Initialize Mono"</Description>
      <Options moHideChildren="1"/>
      <LastState Activated="1"/>
      <Color>FF8080</Color>
      <VariableType>Auto Assembler Script</VariableType>
      <AssemblerScript>[ENABLE]
{$lua}
if syntaxcheck then return end

local processName = "Dojo NTR.exe"
local pid = getProcessIDFromProcessName(processName)

if (pid == 0 or pid == nil) then
    -- 1. Notify the user
    showMessage("Start Game Process First..!!!")
    -- 2. Force the script to "crash" out of the Enable phase
    error("Process not found")
else
    -- Process found, proceed
    OpenProcess(processName)
    mono_initialize()
    LaunchMonoDataCollector()
    beep()                                               --For Sound
    showMessage("Made By DANGER DASH...!!!")             --Pop Up Message
end
{$asm}

[DISABLE]
{$lua}
if process then
    showMessage('Table Disabled!')
end
{$asm}

</AssemblerScript>
      <CheatEntries>
        <CheatEntry>
          <ID>3</ID>
          <Description>"UserData"</Description>
          <Options moHideChildren="1" moAllowManualCollapseAndExpand="1"/>
          <LastState Activated="1"/>
          <Color>80FFFF</Color>
          <VariableType>Auto Assembler Script</VariableType>
          <AssemblerScript>{
  Game   : Dojo NTR.exe
  Author : DANGER DASH
}

define(address1,"GameAssembly.dll"+478890)
define(bytes1,29 51 50 C3 CC)

define(address2,"GameAssembly.dll"+477C00)
define(bytes2,48 89 5C 24 08)

[ENABLE]

assert(address1,bytes1)
assert(address2,bytes2)

alloc(newmem,$2000,"GameAssembly.dll")

label(code1)
label(return1)
label(code2)
label(return2)
label(userdata_ptr)

// --- Logic for ConsumeEnergy ---
newmem:
  mov [userdata_ptr],rcx // Store pointer
code1:
  sub [rcx+50],edx
  ret
  int 3
  jmp return1

// --- Logic for AddEnergy ---
align 10
newmem2:
  mov [userdata_ptr],rcx // Store same pointer here too
code2:
  mov [rsp+08],rbx
  jmp return2

// --- Data Storage ---
userdata_ptr:
  dq 0

// --- Injection Points ---
address1:
  jmp newmem
return1:

address2:
  jmp newmem2
return2:

registersymbol(userdata_ptr)

[DISABLE]

address1:
  db bytes1

address2:
  db bytes2

unregistersymbol(userdata_ptr)
dealloc(newmem)
</AssemblerScript>
