1AB9C6D944F: 00 00                          - add [rax],al
1AB9C6D9451: 00 00                          - add [rax],al
1AB9C6D9453: 00 00                          - add [rax],al
1AB9C6D9455: 00 00                          - add [rax],al
1AB9C6D9457: 00 00                          - add [rax],al
1AB9C6D9459: 00 00                          - add [rax],al
1AB9C6D945B: 00 00                          - add [rax],al
1AB9C6D945D: 00 00                          - add [rax],al
1AB9C6D945F: 00                             - db 00 
// ---------- INJECTING HERE ----------
Player:OnUpdate: 55                             - push rbp
// ---------- DONE INJECTING  ----------
Player:OnUpdate+1: 48 8B EC                       - mov rbp,rsp
Player:OnUpdate+4: 48 83 EC 50                    - sub rsp,50
Player:OnUpdate+8: 48 89 75 F0                    - mov [rbp-10],rsi
Player:OnUpdate+c: 48 89 7D F8                    - mov [rbp-08],rdi
Player:OnUpdate+10: 48 8B F1                       - mov rsi,rcx
Player:OnUpdate+13: 66 66 90                       - nop 3
Player:OnUpdate+16: 49 BB 40 A4 6C 9C AB 01 00 00  - mov r11,Player:StatsUpdate
Player:OnUpdate+20: 41 FF D3                       - call r11
Player:OnUpdate+23: 48 8B BE C8 01 00 00           - mov rdi,[rsi+000001C8]
Player:OnUpdate+2a: 48 63 86 98 00 00 00           - movsxd  rax,dword ptr [rsi+00000098]
}
