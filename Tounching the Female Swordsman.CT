game.exe+4285D: 75 1A           - jne game.exe+42879
game.exe+4285F: 66 0F 6E 41 08  - movd xmm0,[ecx+08]
game.exe+42864: F3 0F E6 C0     - cvtdq2pd xmm0,xmm0
game.exe+42868: 89 01           - mov [ecx],eax
game.exe+4286A: F2 0F 11 41 08  - movsd [ecx+08],xmm0
}
