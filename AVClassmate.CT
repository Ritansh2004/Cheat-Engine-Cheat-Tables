define(address,Ability:set_money)
define(bytes,55 48 8B EC 48 81 EC D0 00 00 00)

[ENABLE]

assert(address,bytes)
alloc(newmem,$1000,Ability:set_money)

label(code)
label(return)

newmem:

mov [UIManager_ability_ptr],rcx

code:
  push rbp
  mov rbp,rsp
  sub rsp,000000D0
  jmp return

UIManager_ability_ptr:
dq 0

address:
  jmp newmem
  nop 6
return:
registersymbol(UIManager_ability_ptr)

[DISABLE]

address:
  db bytes
  // push rbp
  // mov rbp,rsp
  // sub rsp,000000D0

dealloc(newmem)
unregistersymbol(UIManager_ability_ptr)

{
// ORIGINAL CODE - INJECTION POINT: Ability:set_money

1F816544B19: 04 02                 - add al,02
1F816544B1B: 05 04 03 01 50        - add eax,50010304
