define(address,PlayerCombat:Update)
define(bytes,55 48 8B EC 48 83 EC 70)

[ENABLE]

assert(address,bytes)
alloc(newmem,$1000,PlayerCombat:Update)

label(code)
label(return)

newmem:
mov [playercombat_ptr],rcx

code:
  push rbp
  mov rbp,rsp
  sub rsp,70
  jmp return

playercombat_ptr:
dq 0

address:
  jmp newmem
  nop 3
return:
registersymbol(playercombat_ptr)

