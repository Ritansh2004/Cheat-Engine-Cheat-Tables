  This script does blah blah blah
}

define(address,Player_Muu:Update)
define(bytes,55 48 8B EC 48 81 EC 10 08 00 00)

[ENABLE]

assert(address,bytes)
alloc(newmem,$1000,Player_Muu:Update)

label(code)
label(return)

newmem:
mov [player_muu_ptr],rcx

code:
  push rbp
  mov rbp,rsp
  sub rsp,00000810
  jmp return

player_muu_ptr:
dq 0

address:
  jmp newmem
  nop 6
return:
registersymbol(player_muu_ptr)

[DISABLE]

address:
