15FFFB5F7ED: 00 00                          - add [rax],al
15FFFB5F7EF: 00                             - db 00 
// ---------- INJECTING HERE ----------
Train:Update: 55                             - push rbp
// ---------- DONE INJECTING  ----------
Train:Update+1: 48 8B EC                       - mov rbp,rsp
Train:Update+4: 48 81 EC E0 00 00 00           - sub rsp,000000E0
Train:Update+b: 48 89 75 E8                    - mov [rbp-18],rsi
Train:Update+f: 48 89 7D F0                    - mov [rbp-10],rdi
Train:Update+13: 4C 89 7D F8                    - mov [rbp-08],r15
Train:Update+17: 48 8B F1                       - mov rsi,rcx
Train:Update+1a: C7 85 70 FF FF FF 00 00 00 00  - mov [rbp-00000090],00000000
Train:Update+24: C7 85 74 FF FF FF 00 00 00 00  - mov [rbp-0000008C],00000000
Train:Update+2e: C7 85 78 FF FF FF 00 00 00 00  - mov [rbp-00000088],00000000
Train:Update+38: C7 85 7C FF FF FF 00 00 00 00  - mov [rbp-00000084],00000000
}
