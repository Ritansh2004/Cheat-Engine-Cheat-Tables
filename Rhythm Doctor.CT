define(address,scnGame:Update)
define(bytes,55 48 8B EC 48 81 EC 50 03 00 00)

[ENABLE]

assert(address,bytes)
alloc(newmem,$1000,scnGame:Update)

label(code)
label(return)

newmem:
mov [scngame_ptr],rcx

code:
  push rbp
  mov rbp,rsp
  sub rsp,00000350
  jmp return

scngame_ptr:
dq 0

address:
  jmp newmem
  nop 6
return:
registersymbol(scngame_ptr)

