1F816544B26: 00 00                 - add [rax],al
1F816544B28: 00 00                 - add [rax],al
1F816544B2A: 00 00                 - add [rax],al
1F816544B2C: 00 00                 - add [rax],al
1F816544B2E: 00 00                 - add [rax],al
// ---------- INJECTING HERE ----------
Ability:set_money: 55                    - push rbp
// ---------- DONE INJECTING  ----------
Ability:set_money+1: 48 8B EC              - mov rbp,rsp
Ability:set_money+4: 48 81 EC D0 00 00 00  - sub rsp,000000D0
Ability:set_money+b: 48 89 75 F8           - mov [rbp-08],rsi
Ability:set_money+f: 48 8B F1              - mov rsi,rcx
Ability:set_money+12: 48 89 95 78 FF FF FF  - mov [rbp-00000088],rdx
Ability:set_money+19: 48 8B C2              - mov rax,rdx
Ability:set_money+1c: 85 C0                 - test eax,eax
Ability:set_money+1e: 0F 8C AD 01 00 00     - jl Ability:set_money+1d1
Ability:set_money+24: 48 63 85 78 FF FF FF  - movsxd  rax,dword ptr [rbp-00000088]
Ability:set_money+2b: 89 46 18              - mov [rsi+18],eax
}
</AssemblerScript>
