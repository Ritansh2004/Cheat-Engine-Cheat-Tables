// ORIGINAL CODE - INJECTION POINT: PlayerCollisions:LateUpdate

2449C8B1E29: 04 02                          - add al,02
2449C8B1E2B: 05 04 03 01 50                 - add eax,50010304
2449C8B1E30: 00 00                          - add [rax],al
2449C8B1E32: 00 00                          - add [rax],al
