define(address,MyPlayer:Update)
define(bytes,55 48 8B EC 48 81 EC 50 02 00 00)

[ENABLE]

assert(address,bytes)
alloc(newmem,$1000,MyPlayer:Update)

label(code)
label(return)

newmem:
mov [myplayer_ptr],rcx

code:
  push rbp
  mov rbp,rsp
  sub rsp,00000250
  jmp return

myplayer_ptr:
dq 0

address:
  jmp newmem
  nop 6
return:
registersymbol(myplayer_ptr)

[DISABLE]

