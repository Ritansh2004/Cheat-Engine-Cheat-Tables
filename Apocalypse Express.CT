          <Color>80FFFF</Color>
          <VariableType>Auto Assembler Script</VariableType>
          <AssemblerScript>{ Game   : Apocalypse Express.exe
  Version: 
  Date   : 2025-12-30
  Author : DANGER DASH

  This script does blah blah blah
}

define(address,Train:Update)
define(bytes,55 48 8B EC 48 81 EC D0 01 00 00)

[ENABLE]

assert(address,bytes)
alloc(newmem,$1000,Train:Update)

label(code)
label(return)

newmem:
mov [train_ptr],rcx

code:
  push rbp
  mov rbp,rsp
  sub rsp,000001D0
  jmp return

train_ptr:
dq 0

address:
  jmp newmem
  nop 6
return:
registersymbol(train_ptr)

[DISABLE]

address:
  db bytes
  // push rbp
  // mov rbp,rsp
  // sub rsp,000000E0

dealloc(newmem)
unregistersymbol(train_ptr)

{
// ORIGINAL CODE - INJECTION POINT: Train:Update

15FFFB5F7DD: 00 00                          - add [rax],al
15FFFB5F7DF: 00 00                          - add [rax],al
15FFFB5F7E1: 00 00                          - add [rax],al
15FFFB5F7E3: 00 00                          - add [rax],al
