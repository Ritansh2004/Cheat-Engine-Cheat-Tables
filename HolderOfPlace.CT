}

define(address,ADV.CombatControl:Update)
define(bytes,55 48 8B EC 48 83 EC 50 48 89 75 E8 48 89 7D F0)

[ENABLE]

assert(address,bytes)
alloc(newmem,$1000,ADV.CombatControl:Update)

label(code)
label(return)

newmem:
mov [combatcontrol_ptr],rcx

code:
  push rbp
  mov rbp,rsp
  sub rsp,50
  mov [rbp-18],rsi
  mov [rbp-10],rdi
  jmp return

combatcontrol_ptr:
dq 0

address:
  jmp far newmem
  nop 2
return:
registersymbol(combatcontrol_ptr)

[DISABLE]

address:
  db bytes
  // push rbp
