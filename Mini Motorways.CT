3D8C85CE: 00 00        - add [eax],al
// ---------- INJECTING HERE ----------
Motorways.UpgradeDatabase:ConsumeUpgrade: 55           - push ebp
// ---------- DONE INJECTING  ----------
Motorways.UpgradeDatabase:ConsumeUpgrade+1: 8B EC        - mov ebp,esp
Motorways.UpgradeDatabase:ConsumeUpgrade+3: 53           - push ebx
Motorways.UpgradeDatabase:ConsumeUpgrade+4: 57           - push edi
Motorways.UpgradeDatabase:ConsumeUpgrade+5: 56           - push esi
Motorways.UpgradeDatabase:ConsumeUpgrade+6: 83 EC 1C     - sub esp,1C
Motorways.UpgradeDatabase:ConsumeUpgrade+9: 8B 5D 08     - mov ebx,[ebp+08]
Motorways.UpgradeDatabase:ConsumeUpgrade+c: 8B 75 0C     - mov esi,[ebp+0C]
Motorways.UpgradeDatabase:ConsumeUpgrade+f: 8B 45 10     - mov eax,[ebp+10]
Motorways.UpgradeDatabase:ConsumeUpgrade+12: 89 44 24 08  - mov [esp+08],eax
Motorways.UpgradeDatabase:ConsumeUpgrade+16: 89 74 24 04  - mov [esp+04],esi
}
