<?xml version="1.0" encoding="utf-8"?>
<CheatTable CheatEngineTableVersion="46">
  <CheatEntries>
    <CheatEntry>
      <ID>533</ID>
      <Description>"Initialize Mono"</Description>
      <Options moHideChildren="1"/>
      <LastState Activated="1"/>
      <Color>FF8080</Color>
      <VariableType>Auto Assembler Script</VariableType>
      <AssemblerScript>[ENABLE]
{$lua}
if syntaxcheck then return end

local processName = "Power Fantasy.exe"
local pid = getProcessIDFromProcessName(processName)

if (pid == 0 or pid == nil) then
    -- 1. Notify the user
    showMessage("Start Game Process First..!!!")
    -- 2. Force the script to "crash" out of the Enable phase
    error("Process not found")
else
    -- Process found, proceed
    OpenProcess(processName)
    mono_initialize()
    LaunchMonoDataCollector()
    beep()                                               --For Sound
    showMessage("Made By DANGER DASH...!!!")             --Pop Up Message
end
{$asm}

[DISABLE]
{$lua}
if process then
    showMessage('Table Disabled!')
end
{$asm}
</AssemblerScript>
      <CheatEntries>
        <CheatEntry>
          <ID>538</ID>
          <Description>"Option's"</Description>
          <Options moHideChildren="1" moAllowManualCollapseAndExpand="1"/>
          <LastState/>
          <Color>80FFFF</Color>
          <VariableType>Auto Assembler Script</VariableType>
          <AssemblerScript>{
  Game    : Power Fantasy.exe
  Author  : DANGER DASH
}

// --- DEFINITIONS ---
define(addr_1,PlayerController:Update)
define(bytes_1,55 48 8B EC 48 81 EC 40 02 00 00)

define(addr_2,PlayerHealth:TakeDamage)
define(bytes_2,55 48 8B EC 48 81 EC 30 02 00 00)

define(addr_3,PlayerStats:GetWalkSpeed)
define(bytes_3,48 83 EC 08 48 89 34 24)

define(addr_4,EnemyController:Update)
define(bytes_4,55 48 8B EC 48 81 EC C0 08 00 00)

define(addr_5,SpawnManager:Update)
define(bytes_5,55 48 8B EC 48 83 EC 30)

define(addr_6,MerchantManager:AddCoins)
define(bytes_6,55 48 8B EC 48 81 EC 20 01 00 00)

define(addr_7,UltimateManager:Update)
define(bytes_7,55 48 8B EC 48 83 EC 40)

[ENABLE]

assert(addr_1,bytes_1)
assert(addr_2,bytes_2)
assert(addr_3,bytes_3)
assert(addr_4,bytes_4)
assert(addr_5,bytes_5)
assert(addr_6,bytes_6)
assert(addr_7,bytes_7)

alloc(newmem,$4000)

// --- LABELS ---
label(code_1) label(ret_1) label(playercontroller_ptr)
label(code_2) label(ret_2) label(playerhealth_ptr)
label(code_3) label(ret_3) label(playerstats_ptr)
label(code_4) label(ret_4) label(enemycontroller_ptr)
label(code_5) label(ret_5) label(spawnmanager_ptr)
label(code_6) label(ret_6) label(merchantmanager_ptr)
label(code_7) label(ret_7) label(ultimatemanager_ptr)

newmem:

// --- 1. PlayerController ---
code_1:
  mov [playercontroller_ptr],rcx
  push rbp
  mov rbp,rsp
  sub rsp,00000240
  jmp ret_1
playercontroller_ptr:
  dq 0

// --- 2. PlayerHealth ---
code_2:
  mov [playerhealth_ptr],rcx
  push rbp
  mov rbp,rsp
  sub rsp,00000230
  jmp ret_2
playerhealth_ptr:
  dq 0

// --- 3. PlayerStats ---
code_3:
  mov [playerstats_ptr],rcx
  sub rsp,08
  mov [rsp],rsi
  jmp ret_3
playerstats_ptr:
  dq 0

// --- 4. EnemyController ---
code_4:
  mov [enemycontroller_ptr],rcx
  push rbp
  mov rbp,rsp
  sub rsp,000008C0
  jmp ret_4
enemycontroller_ptr:
  dq 0

// --- 5. SpawnManager ---
code_5:
  mov [spawnmanager_ptr],rcx
  push rbp
  mov rbp,rsp
  sub rsp,30
  jmp ret_5
spawnmanager_ptr:
  dq 0

// --- 6. MerchantManager ---
code_6:
  mov [merchantmanager_ptr],rcx
  push rbp
  mov rbp,rsp
  sub rsp,00000120
  jmp ret_6
merchantmanager_ptr:
  dq 0

// --- 7. UltimateManager ---
code_7:
  mov [ultimatemanager_ptr],rcx
  push rbp
  mov rbp,rsp
  sub rsp,40
  jmp ret_7
ultimatemanager_ptr:
  dq 0

// --- INJECTION POINTS ---
addr_1:
  jmp code_1
  nop 6
ret_1:

addr_2:
  jmp code_2
  nop 6
ret_2:

addr_3:
  jmp code_3
  nop 3
ret_3:

addr_4:
  jmp code_4
  nop 6
ret_4:

addr_5:
  jmp code_5
  nop 3
ret_5:

addr_6:
  jmp code_6
  nop 6
ret_6:

addr_7:
  jmp code_7
  nop 3
ret_7:

registersymbol(playercontroller_ptr)
registersymbol(playerhealth_ptr)
registersymbol(playerstats_ptr)
registersymbol(enemycontroller_ptr)
registersymbol(spawnmanager_ptr)
registersymbol(merchantmanager_ptr)
registersymbol(ultimatemanager_ptr)

[DISABLE]

addr_1:
  db bytes_1
addr_2:
  db bytes_2
addr_3:
  db bytes_3
addr_4:
  db bytes_4
addr_5:
  db bytes_5
addr_6:
  db bytes_6
addr_7:
  db bytes_7

unregistersymbol(playercontroller_ptr)
unregistersymbol(playerhealth_ptr)
unregistersymbol(playerstats_ptr)
unregistersymbol(enemycontroller_ptr)
unregistersymbol(spawnmanager_ptr)
unregistersymbol(merchantmanager_ptr)
unregistersymbol(ultimatemanager_ptr)
dealloc(newmem)

{
// --- ORIGINAL CODE REFERENCE ---

// 1. PlayerController:Update
// PlayerController:Update: 55 - push rbp
