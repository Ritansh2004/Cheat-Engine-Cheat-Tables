  Author : DANGER DASH

  This script does blah blah blah
}

define(address,PlayerData:Update)
define(bytes,55 48 8B EC 48 83 EC 40)

[ENABLE]

assert(address,bytes)
alloc(newmem,$1000,PlayerData:Update)

label(code)
label(return)

newmem:
mov [playerdata_ptr],rcx

code:
  push rbp
  mov rbp,rsp
  sub rsp,40
  jmp return

playerdata_ptr:
dq 0

address:
  jmp newmem
  nop 3
return:
registersymbol(playerdata_ptr)

[DISABLE]

address:
  db bytes
  // push rbp
  // mov rbp,rsp
  // sub rsp,40

dealloc(newmem)
unregistersymbol(playerdata_ptr)

