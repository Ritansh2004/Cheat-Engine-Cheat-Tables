<?xml version="1.0" encoding="utf-8"?>
<CheatTable CheatEngineTableVersion="46">
  <CheatEntries>
    <CheatEntry>
      <ID>109</ID>
      <Description>"Initialize Mono"</Description>
      <Options moHideChildren="1"/>
      <LastState Activated="1"/>
      <Color>FF8080</Color>
      <VariableType>Auto Assembler Script</VariableType>
      <AssemblerScript>[ENABLE]

{$lua}
OpenProcess("Smash Hit Museum.exe")
{$asm}

{$lua}
if syntaxcheck then return end
if process and readInteger(process) ~= 0 then
    mono_initialize()
    LaunchMonoDataCollector()
    beep()                                         --For Sound
else
    local msg = 'Please Attach to the Game First!'
    print(msg)
    error(msg)
    beep(msg)
    showMessage('Mono Initialize Failed!')         --Pop Up Message
end
{$asm}

[DISABLE]
{$lua}
showMessage('Table Disabled!')
{$asm}

</AssemblerScript>
      <CheatEntries>
        <CheatEntry>
          <ID>1</ID>
          <Description>"SaveManager"</Description>
          <Options moHideChildren="1"/>
          <LastState Activated="1"/>
          <Color>80FFFF</Color>
          <VariableType>Auto Assembler Script</VariableType>
          <AssemblerScript>{ Game   : Smash Hit Museum.exe
  Version: 
  Date   : 2025-12-30
  Author : DANGER DASH

  This script does blah blah blah
}

define(address,SaveManager:AddArtifact)
define(bytes,55 48 8B EC 48 81 EC A0 00 00 00)

[ENABLE]

assert(address,bytes)
alloc(newmem,$1000,SaveManager:AddArtifact)

label(code)
label(return)

newmem:
mov [savemanager_ptr],rcx

code:
  push rbp
  mov rbp,rsp
  sub rsp,000000A0
  jmp return

savemanager_ptr:
dq 0

address:
  jmp newmem
  nop 6
return:
registersymbol(savemanager_ptr)

[DISABLE]

address:
  db bytes
  // push rbp
  // mov rbp,rsp
  // sub rsp,000000A0

dealloc(newmem)
unregistersymbol(savemanager_ptr)

