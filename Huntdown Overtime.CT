213B179E828: 00 00                 - add [rax],al
213B179E82A: 00 00                 - add [rax],al
213B179E82C: 00 00                 - add [rax],al
213B179E82E: 00 00                 - add [rax],al
// ---------- INJECTING HERE ----------
Player:UpdateRestricts: 55                    - push rbp
// ---------- DONE INJECTING  ----------
Player:UpdateRestricts+1: 48 8B EC              - mov rbp,rsp
Player:UpdateRestricts+4: 48 83 EC 40           - sub rsp,40
Player:UpdateRestricts+8: 48 89 75 F8           - mov [rbp-08],rsi
Player:UpdateRestricts+c: 48 8B F1              - mov rsi,rcx
Player:UpdateRestricts+f: C6 86 34 05 00 00 00  - mov byte ptr [rsi+00000534],00
Player:UpdateRestricts+16: C6 86 35 05 00 00 00  - mov byte ptr [rsi+00000535],00
Player:UpdateRestricts+1d: C6 86 37 05 00 00 00  - mov byte ptr [rsi+00000537],00
