2449C8B1E3C: 00 00                          - add [rax],al
2449C8B1E3E: 00 00                          - add [rax],al
// ---------- INJECTING HERE ----------
PlayerCollisions:LateUpdate: 55                             - push rbp
// ---------- DONE INJECTING  ----------
PlayerCollisions:LateUpdate+1: 48 8B EC                       - mov rbp,rsp
PlayerCollisions:LateUpdate+4: 48 83 EC 30                    - sub rsp,30
PlayerCollisions:LateUpdate+8: 48 89 75 F8                    - mov [rbp-08],rsi
PlayerCollisions:LateUpdate+c: 48 8B F1                       - mov rsi,rcx
PlayerCollisions:LateUpdate+f: 48 8D AD 00 00 00 00           - lea rbp,[rbp+00000000]
PlayerCollisions:LateUpdate+16: 49 BB 90 21 8B 9C 44 02 00 00  - mov r11,PlayerCollisions:CheckCollisions
PlayerCollisions:LateUpdate+20: 41 FF D3                       - call r11
PlayerCollisions:LateUpdate+23: 48 8B CE                       - mov rcx,rsi
PlayerCollisions:LateUpdate+26: 49 BB B0 29 8B 9C 44 02 00 00  - mov r11,PlayerCollisions:CheckForPitfalls
PlayerCollisions:LateUpdate+30: 41 FF D3                       - call r11
}
