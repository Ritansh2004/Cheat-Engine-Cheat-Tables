define(bytes,48 83 EC 08 48 89 34 24)

[ENABLE]

assert(address,bytes)
alloc(newmem,$1000,Player:LateUpdate)

label(code)
label(return)

newmem:
mov [player_ptr],rcx

code:
  sub rsp,08
  mov [rsp],rsi
  jmp return

player_ptr:
dq 0

address:
  jmp newmem
  nop 3
return:
registersymbol(player_ptr)

