define(address,BehaviourScripts.Shop.Service.ShopService:TriggerShowShop)
define(bytes,55 48 8B EC 48 83 EC 30)

[ENABLE]

assert(address,bytes)
alloc(newmem,$1000,BehaviourScripts.Shop.Service.ShopService:TriggerShowShop)

label(code)
label(return)

newmem:
mov [shopservice_ptr],rcx

code:
  push rbp
  mov rbp,rsp
  sub rsp,30
  jmp return

shopservice_ptr:
dq 0

address:
  jmp newmem
  nop 3
return:
registersymbol(shopservice_ptr)

[DISABLE]

address:
  db bytes
  // push rbp
  // mov rbp,rsp
  // sub rsp,30

dealloc(newmem)
unregistersymbol(shopservice_ptr)

