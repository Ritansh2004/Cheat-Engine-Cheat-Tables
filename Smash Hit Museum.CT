2926230F906: F7 6A 90              - imul [rdx-70]
2926230F909: 02 00                 - add al,[rax]
2926230F90B: 00 41 FF              - add [rcx-01],al
2926230F90E: D3 08                 - ror [rax],cl
2926230F910: D0 A3 B5 50 92 02     - shl byte ptr [rbx+029250B5],1
2926230F916: 00 00                 - add [rax],al
2926230F918: 00 00                 - add [rax],al
2926230F91A: 00 00                 - add [rax],al
2926230F91C: 00 00                 - add [rax],al
2926230F91E: 00 00                 - add [rax],al
// ---------- INJECTING HERE ----------
SaveManager:AddArtifact: 55                    - push rbp
// ---------- DONE INJECTING  ----------
SaveManager:AddArtifact+1: 48 8B EC              - mov rbp,rsp
SaveManager:AddArtifact+4: 48 81 EC A0 00 00 00  - sub rsp,000000A0
SaveManager:AddArtifact+b: 48 89 5D C8           - mov [rbp-38],rbx
SaveManager:AddArtifact+f: 48 89 75 D0           - mov [rbp-30],rsi
SaveManager:AddArtifact+13: 48 89 7D D8           - mov [rbp-28],rdi
SaveManager:AddArtifact+17: 4C 89 65 E0           - mov [rbp-20],r12
SaveManager:AddArtifact+1b: 4C 89 6D E8           - mov [rbp-18],r13
SaveManager:AddArtifact+1f: 4C 89 75 F0           - mov [rbp-10],r14
SaveManager:AddArtifact+23: 4C 89 7D F8           - mov [rbp-08],r15
SaveManager:AddArtifact+27: 48 8B F9              - mov rdi,rcx
}
