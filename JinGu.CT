<?xml version="1.0" encoding="utf-8"?>
<CheatTable CheatEngineTableVersion="46">
  <CheatEntries>
    <CheatEntry>
      <ID>228</ID>
      <Description>"Initialize Mono"</Description>
      <Options moHideChildren="1"/>
      <LastState Activated="1"/>
      <Color>FF8080</Color>
      <VariableType>Auto Assembler Script</VariableType>
      <AssemblerScript>[ENABLE]
{$lua}
if syntaxcheck then return end

local processName = "JinGu.exe"
local pid = getProcessIDFromProcessName(processName)

if (pid == 0 or pid == nil) then
    -- 1. Notify the user
    showMessage("Start Game Process First..!!!")
    -- 2. Force the script to "crash" out of the Enable phase
    error("Process not found")
else
    -- Process found, proceed
    OpenProcess(processName)
    mono_initialize()
    LaunchMonoDataCollector()
    beep()                                               --For Sound
    showMessage("Made By DANGER DASH...!!!")             --Pop Up Message
end
{$asm}

[DISABLE]
{$lua}
if process then
    showMessage('Table Disabled!')
end
{$asm}

</AssemblerScript>
      <CheatEntries>
        <CheatEntry>
          <ID>0</ID>
          <Description>"Role"</Description>
          <Options moHideChildren="1" moAllowManualCollapseAndExpand="1"/>
          <LastState/>
          <Color>80FFFF</Color>
          <VariableType>Auto Assembler Script</VariableType>
          <AssemblerScript>{ Game   : JinGu.exe
  Version: 
  Date   : 2026-05-17
  Author : DANGER DASH

  This script does blah blah blah
}

define(address,Role:set_CurHp)
define(bytes,55 48 8B EC 48 81 EC E0 00 00 00)

[ENABLE]

assert(address,bytes)
alloc(newmem,$1000,Role:set_CurHp)

label(code)
label(return)

newmem:
mov [role_takedamage_ptr],rcx
mov [role_givedamage_ptr],rsi

code:
  push rbp
  mov rbp,rsp
  sub rsp,000000E0
  jmp return

role_takedamage_ptr:
dq 0

role_givedamage_ptr:
dq 0

address:
  jmp newmem
  nop 6
return:
registersymbol(role_takedamage_ptr)
registersymbol(role_givedamage_ptr)

[DISABLE]

address:
  db bytes
  // push rbp
  // mov rbp,rsp
  // sub rsp,000000E0

dealloc(newmem)
unregistersymbol(role_takedamage_ptr)
unregistersymbol(role_givedamage_ptr)

{
// ORIGINAL CODE - INJECTION POINT: Role:set_CurHp

1DFDFADF58C: 00 00                 - add [rax],al
1DFDFADF58E: 00 00                 - add [rax],al
1DFDFADF590: 00 00                 - add [rax],al
1DFDFADF592: 00 00                 - add [rax],al
1DFDFADF594: 00 00                 - add [rax],al
1DFDFADF596: 00 00                 - add [rax],al
1DFDFADF598: 00 00                 - add [rax],al
1DFDFADF59A: 00 00                 - add [rax],al
1DFDFADF59C: 00 00                 - add [rax],al
1DFDFADF59E: 00 00                 - add [rax],al
// ---------- INJECTING HERE ----------
Role:set_CurHp: 55                    - push rbp
// ---------- DONE INJECTING  ----------
Role:set_CurHp+1: 48 8B EC              - mov rbp,rsp
Role:set_CurHp+4: 48 81 EC E0 00 00 00  - sub rsp,000000E0
Role:set_CurHp+b: 48 89 5D C8           - mov [rbp-38],rbx
Role:set_CurHp+f: 48 89 75 D0           - mov [rbp-30],rsi
Role:set_CurHp+13: 48 89 7D D8           - mov [rbp-28],rdi
Role:set_CurHp+17: 4C 89 65 E0           - mov [rbp-20],r12
Role:set_CurHp+1b: 4C 89 6D E8           - mov [rbp-18],r13
Role:set_CurHp+1f: 4C 89 75 F0           - mov [rbp-10],r14
Role:set_CurHp+23: 4C 89 7D F8           - mov [rbp-08],r15
Role:set_CurHp+27: 48 8B F9              - mov rdi,rcx
}
