define(bytes,55 48 8B EC 48 83 EC 30)

[ENABLE]

assert(address,bytes)
alloc(newmem,$1000,DebugTool:Update)

label(code)
label(return)

newmem:
mov [debugtool_ptr],rcx

code:
  push rbp
  mov rbp,rsp
  sub rsp,30
  jmp return

debugtool_ptr:
dq 0

address:
  jmp newmem
  nop 3
return:
registersymbol(debugtool_ptr)

[DISABLE]

address:
