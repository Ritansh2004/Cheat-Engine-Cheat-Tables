  Date   : 2026-05-10
  Author : DANGER DASH

  This script does blah blah blah
}

define(address,Player:UpdateRestricts)
define(bytes,55 48 8B EC 48 83 EC 40)

[ENABLE]

assert(address,bytes)
alloc(newmem,$1000,Player:UpdateRestricts)

label(code)
label(return)

newmem:
mov [player_ptr],rcx

code:
  push rbp
  mov rbp,rsp
  sub rsp,40
  jmp return

player_ptr:
dq 0

address:
  jmp newmem
  nop 3
return:
registersymbol(player_ptr)

[DISABLE]

address:
  db bytes
  // push rbp
  // mov rbp,rsp
  // sub rsp,40

dealloc(newmem)
unregistersymbol(player_ptr)
