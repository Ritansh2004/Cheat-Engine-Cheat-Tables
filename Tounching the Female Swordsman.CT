define(address,"game.exe"+42852)
define(bytes,29 41 08 5E 8B E5)

[ENABLE]

assert(address,bytes)
alloc(newmem,$1000)

label(code)
label(return)

newmem:
mov [Pointer_ptr],ecx

code:
  sub [ecx+08],eax
  pop esi
  mov esp,ebp
  jmp return

Pointer_ptr:
dd 0

address:
  jmp newmem
  nop
return:
registersymbol(Pointer_ptr)

[DISABLE]

address:
  db bytes
  // sub [ecx+08],eax
  // pop esi
  // mov esp,ebp

dealloc(newmem)
unregistersymbol(Pointer_ptr)

{
