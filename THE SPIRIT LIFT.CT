define(address,prettysmart.RunManager:Update)
define(bytes,55 48 8B EC 48 83 EC 40)

[ENABLE]

assert(address,bytes)
alloc(newmem,$1000,prettysmart.RunManager:Update)

label(code)
label(return)

newmem:
mov [runmanager_ptr],rcx

code:
  push rbp
  mov rbp,rsp
  sub rsp,40
  jmp return

runmanager_ptr:
dq 0

address:
  jmp newmem
  nop 3
return:
registersymbol(runmanager_ptr)

