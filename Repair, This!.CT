define(address,PlayerCharacter:AddMoney)
define(bytes,55 48 8B EC 48 81 EC E0 02 00 00)

[ENABLE]

assert(address,bytes)
alloc(newmem,$1000,PlayerCharacter:AddMoney)

label(code)
label(return)

newmem:
mov [playercharacter_ptr],rcx

code:
  push rbp
  mov rbp,rsp
  sub rsp,000002E0
  jmp return

playercharacter_ptr:
dq 0

address:
  jmp newmem
  nop 6
return:
registersymbol(playercharacter_ptr)

[DISABLE]

address:
  db bytes
  // push rbp
  // mov rbp,rsp
  // sub rsp,000002E0

dealloc(newmem)
unregistersymbol(playercharacter_ptr)

{
