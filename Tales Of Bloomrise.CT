                  <ID>113</ID>
                  <Description>"Max Regen (Constant Health Recovery)"</Description>
                  <LastState/>
                  <Color>80FFFF</Color>
                  <VariableType>Auto Assembler Script</VariableType>
                  <AssemblerScript>[ENABLE]
{$lua}
local P=_G.BLOOMRISE_P
if P and P.rs~=0 then
  writeFloat(P.rs+0x058,999)
  writeInteger(P.rs+0x05C,1)
  print("[Bloomrise] Max Regen ON")
end
{$asm}
[DISABLE]
{$lua}
local P=_G.BLOOMRISE_P
if P and P.rs~=0 then
  writeFloat(P.rs+0x058,0) writeInteger(P.rs+0x05C,0)
  print("[Bloomrise] Max Regen OFF")
end
{$asm}
          
</AssemblerScript>
