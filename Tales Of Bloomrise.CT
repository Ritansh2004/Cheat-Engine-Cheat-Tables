<?xml version="1.0" encoding="utf-8"?>
<CheatTable CheatEngineTableVersion="46">
  <CheatEntries>
    <CheatEntry>
      <ID>811</ID>
      <Description>"Initialize Mono"</Description>
      <Options moHideChildren="1"/>
      <LastState Activated="1"/>
      <Color>FF8080</Color>
      <VariableType>Auto Assembler Script</VariableType>
      <AssemblerScript>[ENABLE]
{$lua}
if syntaxcheck then return end

local processName = "Tales Of Bloomrise.exe"
local pid = getProcessIDFromProcessName(processName)

if (pid == 0 or pid == nil) then
    -- 1. Notify the user
    showMessage("Start Game Process First..!!!")
    -- 2. Force the script to "crash" out of the Enable phase
    error("Process not found")
else
    -- Process found, proceed
    OpenProcess(processName)
    mono_initialize()
    LaunchMonoDataCollector()
    beep()                                               --For Sound
    showMessage("Made By DANGER DASH...!!!")             --Pop Up Message
end
{$asm}

[DISABLE]
{$lua}
if process then
    showMessage('Table Disabled!')
end
{$asm}

</AssemblerScript>
      <CheatEntries>
        <CheatEntry>
          <ID>1</ID>
          <Description>"[ AUTO-INJECT ] Player Instance Resolver"</Description>
          <Options moHideChildren="1" moAllowManualCollapseAndExpand="1"/>
          <LastState Activated="1"/>
          <Color>80FFFF</Color>
          <VariableType>Auto Assembler Script</VariableType>
          <AssemblerScript>[ENABLE]
{$lua}
local function log(msg) print("[Bloomrise] "..tostring(msg)) end
local function hex(n) if not n or n==0 then return "0x0" end return string.format("0x%X",n) end
local function readQ(a) if not a or a==0 then return 0 end local ok,v=pcall(readQword,a) return (ok and v) or 0 end
local function readF(a) if not a or a==0 then return 0.0 end local ok,v=pcall(readFloat,a) return (ok and v) or 0.0 end
local function readI(a) if not a or a==0 then return 0 end local ok,v=pcall(readInteger,a) return (ok and v) or 0 end
local function sym(name,addr) if addr and addr~=0 then registerSymbol(name,addr,true) end end

local function resolveAll()
  mono_OnProcessOpened()
  if not mono_isValid() then log("FATAL: Mono not valid") return nil end
  local cls=mono_findClass("","Player")
  if not cls or cls==0 then log("FATAL: Player class not found") return nil end
  local method=mono_class_findMethod(cls,"get_Instance",0)
  if not method or method==0 then log("FATAL: get_Instance not found") return nil end
  local jit=mono_compile_method(method)
  if not jit or jit==0 then log("FATAL: JIT compile failed") return nil end
  local staticSlot=0
  for i=0,64 do
    local b=readBytes(jit+i,2,true)
    if b and b[1]==0x48 and b[2]==0xB8 then
      local s=readQword(jit+i+2)
      if s and s~=0 then staticSlot=s break end
    end
  end
  if staticSlot==0 then staticSlot=0x124E74734E0 log("WARNING: Using hardcoded fallback slot") end
  local P={}
  P.slot=staticSlot
  P.player=readQ(staticSlot)
  if P.player==0 then log("WARNING: Player* NULL - not in gameplay scene") return P end
  P.pStats=readQ(P.player+0x030)
  P.rs=readQ(P.pStats+0x018)
  P.pStam=readQ(P.player+0x048)
  P.inv=readQ(P.player+0x050)
  P.pMove=readQ(P.player+0x058)
  P.pAtk=readQ(P.player+0x060)
  P.pHealth=readQ(P.player+0x068)
  P.pExp=readQ(P.player+0x070)
  return P
end

local function registerAll(P)
  sym("BLOOMRISE_STATIC_SLOT",P.slot)
  sym("BLOOMRISE_PLAYER",P.player)
  sym("BLOOMRISE_PLAYERSTATS",P.pStats)
  sym("BLOOMRISE_RUNTIMESTATS",P.rs)
  sym("BLOOMRISE_PLAYERSTAMINA",P.pStam)
  sym("BLOOMRISE_INVENTORY",P.inv)
  sym("BLOOMRISE_PLAYERMOVEMENT",P.pMove)
  sym("BLOOMRISE_PLAYERATTACK",P.pAtk)
  sym("BLOOMRISE_PLAYERHEALTH",P.pHealth)
  sym("BLOOMRISE_PLAYEREXP",P.pExp)
  local rs=P.rs
  sym("RS_Level",rs+0x010) sym("RS_Health",rs+0x014) sym("RS_MaxHealth",rs+0x018)
  sym("RS_Stamina",rs+0x01C) sym("RS_MaxStamina",rs+0x020) sym("RS_CurrentExp",rs+0x024)
  sym("RS_NextLevelExp",rs+0x028) sym("RS_BaseDamage",rs+0x02C) sym("RS_CriticalChance",rs+0x030)
  sym("RS_CriticalDamage",rs+0x034) sym("RS_AttrPoints",rs+0x038) sym("RS_Strenght",rs+0x03C)
  sym("RS_Dexterity",rs+0x040) sym("RS_Intelligence",rs+0x044) sym("RS_TotalExp",rs+0x048)
  sym("RS_TotalDmg",rs+0x04C) sym("RS_GoldAmount",rs+0x050) sym("RS_DodgeChance",rs+0x054)
  sym("RS_RegenAmount",rs+0x058) sym("RS_HasRegenSkill",rs+0x05C) sym("RS_DropChanceMult",rs+0x060)
  sym("RS_HasLastResort",rs+0x064) sym("RS_LastResortCooldown",rs+0x068) sym("RS_LastResortTimer",rs+0x06C)
  local ps=P.pStats
  sym("PS_initialLevel",ps+0x020) sym("PS_initialMaxHealth",ps+0x024) sym("PS_initialMaxStamina",ps+0x028)
  sym("PS_initialNextLevelExp",ps+0x02C) sym("PS_ExpMultiplier",ps+0x030) sym("PS_initialBaseDamage",ps+0x034)
  sym("PS_initialCriticalChance",ps+0x038) sym("PS_initialCriticalDamage",ps+0x03C)
  sym("PS_initialDodgeChance",ps+0x040) sym("PS_initialRegenAmount",ps+0x044) sym("PS_initialDropChanceMult",ps+0x048)
  local pm=P.pMove
  sym("PM_speed",pm+0x078) sym("PM_dashSpeed",pm+0x07C) sym("PM_dashDuration",pm+0x080)
  sym("PM_dashStaminaCost",pm+0x084) sym("PM_controlMultiplier",pm+0x08C) sym("PM_speedMultiplier",pm+0x090)
  sym("PM_CanDash",pm+0x09C) sym("PM_canMove",pm+0x0A8) sym("PM_isDashing",pm+0x0A9)
  sym("PM_isFrozen",pm+0x0AA) sym("PM_isJuiceLocked",pm+0x0AB)
  local pa=P.pAtk
  sym("PA_attackVolume",pa+0x10C) sym("PA_hitStopDuration",pa+0x110) sym("PA_fishingCheckRadius",pa+0x118)
  sym("PA_attackRange",pa+0x11C) sym("PA_attackArcDegrees",pa+0x120) sym("PA_minDistanceMeleeAttack",pa+0x128)
  sym("PA_knockbackForce",pa+0x12C) sym("PA_cameraShakeForce",pa+0x130) sym("PA_knockbackDuration",pa+0x134)
  sym("PA_damageMultiplier",pa+0x13C) sym("PA_currentAttackRotation",pa+0x140) sym("PA_hasHitThisAnimation",pa+0x144)
  local ph=P.pHealth
  sym("PH_respawnSlideDuration",ph+0x098) sym("PH_hasdamage",ph+0x09C) sym("PH_damageTest",ph+0x0A0)
  sym("PH_healthBeforeOneLife",ph+0x0A4) sym("PH_hasOneHp",ph+0x0A8)
  local pst=P.pStam
  sym("PST_staminaToRecover",pst+0x048) sym("PST_staminaRegenInterval",pst+0x04C)
  sym("PL_healTimer",P.player+0x0A0) sym("PL_fadeDuration",P.player+0x0A4)
end

local P=resolveAll()
if P then
  registerAll(P)
  _G.BLOOMRISE_P=P
  _G.BLOOMRISE_SLOT=P.slot
  _G.BLOOMRISE_LAST_PLAYER=P.player
  if P.rs and P.rs~=0 then
    log(string.format("=== Player Stats === Level:%d HP:%.1f/%.1f Stamina:%.1f/%.1f Gold:%d Exp:%d BaseDmg:%.1f CritChance:%.1f%% Speed:%.2f",
      readI(P.rs+0x010),readF(P.rs+0x014),readF(P.rs+0x018),
      readF(P.rs+0x01C),readF(P.rs+0x020),readI(P.rs+0x050),
      readI(P.rs+0x024),readF(P.rs+0x02C),readF(P.rs+0x030),readF(P.pMove+0x078)))
  end
end

if _G.BLOOMRISE_TIMER then _G.BLOOMRISE_TIMER.Enabled=false pcall(function() _G.BLOOMRISE_TIMER.destroy() end) end
_G.BLOOMRISE_TIMER=createTimer(nil,false)
_G.BLOOMRISE_TIMER.Interval=3000
_G.BLOOMRISE_TIMER.OnTimer=function()
  local slot=_G.BLOOMRISE_SLOT
  if not slot or slot==0 then return end
  local ok,np=pcall(readQword,slot)
  if not ok or not np or np==0 then return end
  if np==_G.BLOOMRISE_LAST_PLAYER then return end
  local ns=readQword(np+0x030) if not ns or ns==0 then return end
  local nr=readQword(ns+0x018) if not nr or nr==0 then return end
  local NP={slot=slot,player=np,pStats=ns,rs=nr,
    pStam=readQword(np+0x048) or 0,inv=readQword(np+0x050) or 0,
    pMove=readQword(np+0x058) or 0,pAtk=readQword(np+0x060) or 0,
    pHealth=readQword(np+0x068) or 0,pExp=readQword(np+0x070) or 0}
  _G.BLOOMRISE_LAST_PLAYER=np
  _G.BLOOMRISE_P=NP
  registerAll(NP)
  print("[Bloomrise] Scene reload — pointers refreshed. Player @ "..hex(np))
end
_G.BLOOMRISE_TIMER.Enabled=true
log("ENABLED — all symbols registered. Enable this script FIRST before using any entry below.")
{$asm}

[DISABLE]
{$lua}
if _G.BLOOMRISE_TIMER then _G.BLOOMRISE_TIMER.Enabled=false pcall(function() _G.BLOOMRISE_TIMER.destroy() end) _G.BLOOMRISE_TIMER=nil end
local syms={"BLOOMRISE_STATIC_SLOT","BLOOMRISE_PLAYER","BLOOMRISE_PLAYERSTATS","BLOOMRISE_RUNTIMESTATS",
  "BLOOMRISE_PLAYERSTAMINA","BLOOMRISE_INVENTORY","BLOOMRISE_PLAYERMOVEMENT","BLOOMRISE_PLAYERATTACK",
  "BLOOMRISE_PLAYERHEALTH","BLOOMRISE_PLAYEREXP",
  "RS_Level","RS_Health","RS_MaxHealth","RS_Stamina","RS_MaxStamina","RS_CurrentExp","RS_NextLevelExp",
  "RS_BaseDamage","RS_CriticalChance","RS_CriticalDamage","RS_AttrPoints","RS_Strenght","RS_Dexterity",
  "RS_Intelligence","RS_TotalExp","RS_TotalDmg","RS_GoldAmount","RS_DodgeChance","RS_RegenAmount",
  "RS_HasRegenSkill","RS_DropChanceMult","RS_HasLastResort","RS_LastResortCooldown","RS_LastResortTimer",
  "PS_initialLevel","PS_initialMaxHealth","PS_initialMaxStamina","PS_initialNextLevelExp","PS_ExpMultiplier",
  "PS_initialBaseDamage","PS_initialCriticalChance","PS_initialCriticalDamage","PS_initialDodgeChance",
  "PS_initialRegenAmount","PS_initialDropChanceMult",
  "PM_speed","PM_dashSpeed","PM_dashDuration","PM_dashStaminaCost","PM_controlMultiplier","PM_speedMultiplier",
  "PM_CanDash","PM_canMove","PM_isDashing","PM_isFrozen","PM_isJuiceLocked",
  "PA_attackVolume","PA_hitStopDuration","PA_fishingCheckRadius","PA_attackRange","PA_attackArcDegrees",
  "PA_minDistanceMeleeAttack","PA_knockbackForce","PA_cameraShakeForce","PA_knockbackDuration",
  "PA_damageMultiplier","PA_currentAttackRotation","PA_hasHitThisAnimation",
  "PH_respawnSlideDuration","PH_hasdamage","PH_damageTest","PH_healthBeforeOneLife","PH_hasOneHp",
  "PST_staminaToRecover","PST_staminaRegenInterval","PL_healTimer","PL_fadeDuration"}
for _,n in ipairs(syms) do unregisterSymbol(n) end
_G.BLOOMRISE_P=nil _G.BLOOMRISE_SLOT=nil _G.BLOOMRISE_LAST_PLAYER=nil
print("[Bloomrise] DISABLED — all symbols unregistered.")
{$asm}
      
</AssemblerScript>
