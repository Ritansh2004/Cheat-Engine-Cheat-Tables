PlayerCharacter:AddMoney+1: 48 8B EC              - mov rbp,rsp
PlayerCharacter:AddMoney+4: 48 81 EC E0 02 00 00  - sub rsp,000002E0
PlayerCharacter:AddMoney+b: 4C 89 6D E8           - mov [rbp-18],r13
PlayerCharacter:AddMoney+f: 4C 89 75 F0           - mov [rbp-10],r14
PlayerCharacter:AddMoney+13: 4C 89 7D F8           - mov [rbp-08],r15
PlayerCharacter:AddMoney+17: 4C 8B F9              - mov r15,rcx
PlayerCharacter:AddMoney+1a: 48 89 95 70 FD FF FF  - mov [rbp-00000290],rdx
PlayerCharacter:AddMoney+21: 4C 89 85 68 FD FF FF  - mov [rbp-00000298],r8
PlayerCharacter:AddMoney+28: 4C 89 8D 60 FD FF FF  - mov [rbp-000002A0],r9
PlayerCharacter:AddMoney+2f: 49 63 87 98 00 00 00  - movsxd  rax,dword ptr [r15+00000098]
}
